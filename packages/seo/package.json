{
	"name": "@opensky/seo",
	"scripts": {
		"test": "bun test src",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "oxfmt .",
		"lint": "oxfmt --check . && eslint .",
		"dev": "vite dev",
		"build": "svelte-kit sync && svelte-package && publint",
		"prepack": "bun run build",
		"prepare": "svelte-kit sync || echo ''"
	},
	"description": "SvelteKit meta tags and seo utility",
	"author": "notnotjake",
	"version": "1.2.0",
	"repository": {
		"directory": "packages/seo",
		"type": "git",
		"url": "git+https://github.com/open-sky-dev/opensky-seo.git"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"oxfmt": "^0.57.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"keywords": [
		"svelte",
		"sveltekit",
		"metadata",
		"seo",
		"utility",
		"meta-tags",
		"open-graph",
		"head",
		"svelte-meta",
		"svelte-seo"
	],
	"private": false,
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts"
}
