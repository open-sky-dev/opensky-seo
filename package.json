{
	"name": "opensky-seo-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"devDependencies": {
		"@socketsecurity/bun-security-scanner": "^1.1.2"
	},
	"scripts": {
		"build": "bun run --cwd packages/seo build",
		"test": "bun run --cwd packages/seo test",
		"check": "bun run --cwd packages/seo check",
		"lint": "bun run --cwd packages/seo lint",
		"format": "bun run --cwd packages/seo format",
		"example": "bun run --cwd packages/seo build && bun run --cwd examples/sveltekit dev"
	}
}
